------------------------------------------------
-- TP SYSTEM
------------------------------------------------
local tpPoints = {}

local function refreshTPUI(frame)
	for _,v in pairs(frame:GetChildren()) do
		if v:IsA("TextLabel") and v.Name == "slot" then
			v:Destroy()
		end
	end

	for i,point in ipairs(tpPoints) do
		local t = Instance.new("TextLabel")
		t.Name = "slot"
		t.Size = UDim2.new(0,100,0,25)
		t.Position = UDim2.new(0,10,0,50 + (i*25))
		t.Text = "SAVE "..i
		t.BackgroundTransparency = 1
		t.TextColor3 = Color3.fromRGB(255,255,255)
		t.Parent = frame
	end
end

tpBtn.MouseButton1Click:Connect(function()
	clearRight()

	local saveBtn = Instance.new("TextButton")
	saveBtn.Size = UDim2.new(0,150,0,40)
	saveBtn.Position = UDim2.new(0.5,-75,0.2,0)
	saveBtn.Text = "TP SAVE"
	saveBtn.Parent = right

	local runBtn = Instance.new("TextButton")
	runBtn.Size = UDim2.new(0,120,0,40)
	runBtn.Position = UDim2.new(0.1,0,0.8,0)
	runBtn.Text = "RUN"
	runBtn.Parent = right

	local delBtn = Instance.new("TextButton")
	delBtn.Size = UDim2.new(0,120,0,40)
	delBtn.Position = UDim2.new(0.7,0,0.8,0)
	delBtn.Text = "DELETE TP"
	delBtn.Parent = right

	saveBtn.MouseButton1Click:Connect(function()
		if #tpPoints >= 10 then return end
		table.insert(tpPoints, player.Character.HumanoidRootPart.Position)
		refreshTPUI(right)
	end)

	runBtn.MouseButton1Click:Connect(function()
		while #tpPoints > 0 do
			for i = 1, #tpPoints do
				if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
					player.Character.HumanoidRootPart.CFrame = CFrame.new(tpPoints[i])
					task.wait(1)
				end
			end
		end
	end)

	delBtn.MouseButton1Click:Connect(function()
		tpPoints = {}
		refreshTPUI(right)
	end)
end)

