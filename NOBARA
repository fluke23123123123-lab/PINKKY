------------------------------------------------
-- KEY TIMER CHECK
------------------------------------------------
task.spawn(function()
	while true do
		task.wait(5)
		if main.Visible and isExpired() then
			main.Visible = false
			keyFrame.Visible = true
			errorText.Text = "KEY EXPIRED (24H)"
			keyData = nil
		end
	end
end)
